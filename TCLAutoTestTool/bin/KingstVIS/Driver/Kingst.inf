[FW01A1Install.CoInstallers]
AddReg=CoInstallers_AddReg
CopyFiles=CoInstallers_CopyFiles

[FW01A2Install.CoInstallers]
AddReg=CoInstallers_AddReg
CopyFiles=CoInstallers_CopyFiles

[FW01A3Install.CoInstallers]
AddReg=CoInstallers_AddReg
